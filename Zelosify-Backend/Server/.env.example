# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# The server runs inside Docker Compose on port 5445 (mapped from container 5432).
DATABASE_URL="postgresql://postgres:testrun@localhost:5445/zelosify_recruit_test"

# ──────────────────────────────────────────────────────────────────────────────
# AI AGENT — GROQ
# ──────────────────────────────────────────────────────────────────────────────
# Used by the Resume Recommendation Agent (agentOrchestrator.ts → llmCore.ts).
# Model: llama-3.3-70b-versatile (tool-calling enabled).
# Get a free key at: https://console.groq.com
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ──────────────────────────────────────────────────────────────────────────────
# KEYCLOAK (Identity Provider)
# ──────────────────────────────────────────────────────────────────────────────
# Keycloak runs locally via Docker Compose on port 8080.
# Realm: Zelosify  |  Client: dynamic-client
# These values must match your Keycloak realm export exactly.
KEYCLOAK_URL=http://localhost:8080/auth
KEYCLOAK_REALM=Zelosify
KEYCLOAK_CLIENT_ID=dynamic-client
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# Keycloak admin credentials (used by seedTestUsers.ts to create test users).
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# RS256 public key from Keycloak realm → Keys tab → copy the RSA public key value.
# Used to verify JWT access tokens issued by Keycloak.
KEYCLOAK_RS256_SIG=your-keycloak-rs256-public-key

# ──────────────────────────────────────────────────────────────────────────────
# ENCRYPTION (AES-256-GCM)
# ──────────────────────────────────────────────────────────────────────────────
# Used to encrypt S3 upload tokens before sending them to the frontend.
# This prevents clients from forging upload requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# ──────────────────────────────────────────────────────────────────────────────
# AWS S3 (Resume / Profile Storage)
# ──────────────────────────────────────────────────────────────────────────────
# S3 is used to store uploaded vendor resume files.
# Key pattern: <tenantId>/<openingId>/<timestamp>_<filename>
# Presigned URLs are generated for both upload (PUT) and preview (GET).
# The IAM user must have s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket.
S3_AWS_REGION=eu-north-1
S3_ACCESS_KEY_ID=your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=zelosify-recruit-dev
