# ──────────────────────────────────────────────────────────────────────────────
# BACKEND API BASE URL
# ──────────────────────────────────────────────────────────────────────────────
# Next.js rewrites proxy /api/v1/* to this URL (see next.config.js).
# The frontend never calls the backend directly — all calls go through
# the Next.js dev server to avoid CORS issues.
# Default: Vite dev server port 5173 which proxies to Express on 5000.
NEXT_PUBLIC_BACKEND_URL=http://localhost:5173/api/v1
